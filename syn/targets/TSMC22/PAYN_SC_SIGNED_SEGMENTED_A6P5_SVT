#!/bin/bash
# Library-only experiment: accepted pending-bit PaYN RTL mapped to the
# TSMC22 6.5-track SVT C30 base library.  This is a separate target so the
# accepted 7-track SVT + HPK implementation remains untouched.
export TOP=payn_array_signed_segmented
export TECH=TSMC22
export SRC_SV="payn/variants/signed_segmented/payn_array_signed_segmented.sv"
export PERIOD=2.5
export TSMC22_CELL_TIER=sc6p5mcpp140z
export TSMC22_LIB_FLAVORS=svt_c30
export TSMC22_HPK=0
export MULTIBIT_INFER=1
export CLOCK_GATE=1
export POST_LOAD_SCRIPT=tsmc22_sc65_addf_and2_x0p5_only_v2.tcl
export PAYN_A6P5_N=${PAYN_A6P5_N:-8}
export SYN_DEFINES="${SYN_DEFINES:-PAYN_K=8 PAYN_M=16 PAYN_NH=${PAYN_A6P5_N} PAYN_NW=${PAYN_A6P5_N} PAYN_SEG_LOW_W=9}"
export RTL_PREFLIGHT_CMD=${RTL_PREFLIGHT_CMD:-"BUILD_DIR=build/rtl_preflight/signed_segmented_a6p5_svt_n${PAYN_A6P5_N} SIM_SRCS=designs/payn/variants/signed_segmented/payn_array_signed_segmented.sv VCS_ARGS=+define+PAYN_ARRAY_EXTERNAL_RTL+PAYN_ARRAY_DUT=payn_array_signed_segmented+define+SC_K=8+define+SC_M=16+define+SC_NH=${PAYN_A6P5_N}+define+SC_NW=${PAYN_A6P5_N}+define+SC_OWIDTH=24+define+SC_T=128 bash designs/payn/cosim/run_array.sh"}

#!/bin/bash
# PaYN SC accelerator (integrated Sobol banks + peripheral + InnerPE tile grid).
# Default shape K6/M16/9x9/OW24; DesignWare DW02_tree maps from dw_foundation.
export TOP=payn_array
export TECH=TSMC22
export SRC_SV="payn/payn_array.sv"
export PERIOD=2.5
export TSMC22_HPK=1
export MULTIBIT_INFER=1
export CLOCK_GATE=1
# Use the same standard-cell library as the baselines (flow defaults:
# sc7mcpp140z / svt_c30) so the SC-vs-binary power comparison is apples-to-apples.
export RTL_PREFLIGHT_CMD="bash designs/payn/cosim/run_array.sh"

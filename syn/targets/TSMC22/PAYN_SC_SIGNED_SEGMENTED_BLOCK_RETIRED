#!/bin/bash
# Exact block-retired bipolar accumulator. For the accepted K8/M16/T128
# workload it uses a radix-128 low digit and retires sign compensation once
# every eight enabled MAC cycles.
export TOP=payn_array_signed_segmented_block_retired
export TECH=TSMC22
export SRC_SV="payn/variants/signed_segmented_block_retired/payn_array_signed_segmented_block_retired.sv"
export PERIOD=2.5
export TSMC22_HPK=1
export MULTIBIT_INFER=1
export CLOCK_GATE=1
export RTL_PREFLIGHT_CMD=${RTL_PREFLIGHT_CMD:-"BUILD_DIR=build/rtl_preflight/signed_segmented_block_retired SIM_SRCS=designs/payn/variants/signed_segmented_block_retired/payn_array_signed_segmented_block_retired.sv VCS_ARGS=+define+PAYN_ARRAY_EXTERNAL_RTL+PAYN_ARRAY_DUT=payn_array_signed_segmented_block_retired+define+SC_K=8+define+SC_M=16+define+SC_NH=8+define+SC_NW=8+define+SC_OWIDTH=24+define+SC_T=128 bash designs/payn/cosim/run_array.sh"}

#!/bin/bash
# Experimental exact recurrent carry-save low accumulator.  Two redundant
# LOW_W rows remove the recurrent low carry-propagate adder; a small signed
# debt digit defers updates to the wide high bank.  Override LOW_W with
# SYN_DEFINES=PAYN_SEG_LOW_W=<n>.
export TOP=payn_array_signed_segmented_csa
export TECH=TSMC22
export SRC_SV="payn/variants/signed_segmented_csa/payn_array_signed_segmented_csa.sv"
export PERIOD=2.5
export TSMC22_HPK=1
export MULTIBIT_INFER=1
export CLOCK_GATE=1
export RTL_PREFLIGHT_CMD=${RTL_PREFLIGHT_CMD:-"BUILD_DIR=build/rtl_preflight/signed_segmented_csa SIM_SRCS=designs/payn/variants/signed_segmented_csa/payn_array_signed_segmented_csa.sv VCS_ARGS=+define+PAYN_ARRAY_EXTERNAL_RTL+PAYN_ARRAY_DUT=payn_array_signed_segmented_csa+define+SC_K=8+define+SC_M=16+define+SC_NH=8+define+SC_NW=8+define+SC_OWIDTH=24+define+SC_T=128 bash designs/payn/cosim/run_array.sh"}

#!/bin/bash
# APR for the PaYN SC tile-config sweep (see syn/targets/TSMC22/PAYN_SC_SWEEP).
# Shape is baked into the synth netlist; APR just places+routes it. Same recipe
# as PAYN_SC. Use RUN_NAME=<cfg> to name each config's run dir.
export TARGET=TSMC22/PAYN_SC_SWEEP
export SYNTH_RUN=${SYNTH_RUN:?set SYNTH_RUN to the synthesis run name}
export TOP=payn_array
export TECH=TSMC22
export PERIOD=2.5
# Match the synthesis library set so inferred HPK two-bit flops have timing,
# physical, simulation, and power models throughout APR and signoff.
export TSMC22_HPK=1
export POST_LOAD_SCRIPT=apr/scripts/set_clock_uncertainty.tcl
export CORE_UTIL=${CORE_UTIL:-0.70}
export CORE_ASPECT=${CORE_ASPECT:-1.000}

# Optional locality experiment.  The hierarchy defaults below match the
# manually named SC array in designs/payn/inner_pe.sv.  Keep this opt-in so
# existing sweep results retain the original unconstrained placement recipe.
if [ "${SC_PLACE_GUIDES:-0}" = "1" ] && \
   [ "${SC_DISTRIBUTION_GUIDES:-0}" = "1" ]; then
    echo "ERROR: choose tile guides or distribution guides, not both" >&2
    return 2 2>/dev/null || exit 2
elif [ "${SC_PLACE_GUIDES:-0}" = "1" ]; then
    export SC_NH=${SC_NH:?set SC_NH when SC_PLACE_GUIDES=1}
    export SC_NW=${SC_NW:?set SC_NW when SC_PLACE_GUIDES=1}
    export SC_TILE_HIER_STYLE=${SC_TILE_HIER_STYLE:-manual}
    export SC_TILE_HIER_PREFIX=${SC_TILE_HIER_PREFIX:-u_pe/u_array_core}
    export PRE_PLACE_SCRIPT=apr/scripts/place_guides_sc_tiles.tcl
elif [ "${SC_DISTRIBUTION_GUIDES:-0}" = "1" ]; then
    export SC_NH=${SC_NH:?set SC_NH when SC_DISTRIBUTION_GUIDES=1}
    export SC_NW=${SC_NW:?set SC_NW when SC_DISTRIBUTION_GUIDES=1}
    export SC_DIST_HIER_PREFIX=${SC_DIST_HIER_PREFIX:-u_pe/u_array_core}
    export PRE_PLACE_SCRIPT=apr/scripts/place_guides_sc_distribution.tcl
fi

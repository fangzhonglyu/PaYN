#!/bin/bash
# Standalone InnerPE APR -- compare vs payn_array's embedded u_pe. Stock recipe,
# same svt/sc7 library + restored clock uncertainty as PAYN_SC. Block-level (ports
# as pins, no pad ring); the ~4k stochastic-stream ports are on-chip wires in the
# full array, so this floorplan's boundary is somewhat artificial by construction.
export TARGET=TSMC22/SC_INNER_PE
export SYNTH_RUN=${SYNTH_RUN:?set SYNTH_RUN to the synthesis run name}
export TOP=sc_inner_pe_manual_k6m16n9_ow24
export TECH=TSMC22
export PERIOD=2.5
export POST_LOAD_SCRIPT=apr/scripts/set_clock_uncertainty.tcl
export CORE_UTIL=${CORE_UTIL:-0.70}
export CORE_ASPECT=${CORE_ASPECT:-1.000}
